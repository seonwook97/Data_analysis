   "source": [
    "# 문제1\n",
    "- 과제 설명 첫 두 페이지에 제시한 TIOBE INDEX의 상위 9개 언어에 R(14위)까지해서 총 10개 언어에 대해 출판\n",
    "책 정보를 수집하세요."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "da8f0eee",
   "metadata": {},
   "source": [
    "![languages](../data/languages.png)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a91887df",
   "metadata": {},
   "source": [
    "### 특히 주의해야할 점으로는\n",
    "- IT 관련 서적에서 펄 이라는 언어같은 경우는 유명한 작가 펄과 혼돈할 수 있으며\n",
    "- Python과 파이썬 처럼 어떤 경우는 영어와 한글을 각각 따로 검색 후 합쳐야 할 수도 있습니다.\n",
    "- 만약 여러분들이 네이버 API를 사용하는 경우 일일 검색량 제한에 조심하세요\n",
    "- 네이버 API: https://developers.naver.com/docs/search/book/\n",
    "- 네이버 책: https://book.naver.com/"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "637f7709",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Hangul OK in your Windows !!!\n"
     ]
    }
   ],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import os\n",
    "import sys\n",
    "import urllib.request\n",
    "import json\n",
    "import seaborn as sns\n",
    "import warnings\n",
    "import datetime\n",
    "import matplotlib.pyplot as plt\n",
    "import set_matplotlib_hangul\n",
    "\n",
    "warnings.simplefilter(\"ignore\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "bf50a2b2",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 네이버 api id,pw\n",
    "client_id = \"jOc7UxR_Sp1MMk2mwOq1\"\n",
    "client_secret = \"s9PY8Vl3Wz\""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "d21c0f13",
   "metadata": {},
   "outputs": [],
   "source": [
    "def gen_search_url(search_text, start_num, disp_num):\n",
    "    base = \"https://openapi.naver.com/v1/search\"\n",
    "    node = \"/book_adv.json\" \n",
    "    param_title = \"?d_titl=\" + urllib.parse.quote(search_text)\n",
    "    param_start = \"&start=\" + str(start_num)\n",
    "    param_disp = \"&display=\" + str(disp_num)\n",
    "    param_catg = \"&d_catg=280\" # 컴퓨터/IT 카테고리 넘버 = 280\n",
    "    \n",
    "    return base + node + param_title + param_start + param_disp + param_catg "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "95c84e6b",
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_result_onpage(url):\n",
    "    request = urllib.request.Request(url)\n",
    "    request.add_header(\"X-Naver-Client-Id\", client_id)\n",
    "    request.add_header(\"X-Naver-Client-Secret\", client_secret)\n",
    "    response = urllib.request.urlopen(request)\n",
    "    rescode = response.getcode()\n",
    "    print(\"[%s] Url Request Success\" % datetime.datetime.now())\n",
    "    print(response, response.getcode(), response.code, response.status) \n",
    "    return json.loads(response.read().decode(\"utf-8\"))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "50e6391f",
   "metadata": {},
   "outputs": [],
   "source": [
    "def delete_tag(input_str):\n",
    "    input_str = input_str.replace(\"<b>\", \"\")\n",
    "    input_str = input_str.replace(\"</b>\", \"\")\n",
    "    return input_str "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "56a9a52c",
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_fields(json_data):\n",
    "    title = [delete_tag(each[\"title\"]) for each in json_data[\"items\"]]\n",
    "    link = [each[\"link\"] for each in json_data[\"items\"]]\n",
    "    author = [each[\"author\"] for each in json_data[\"items\"]]\n",
    "    price = [each[\"price\"] for each in json_data[\"items\"]]\n",
    "    discount = [each[\"discount\"] for each in json_data[\"items\"]]\n",
    "    publisher = [each[\"publisher\"] for each in json_data[\"items\"]]\n",
    "    isbn = [each[\"isbn\"] for each in json_data[\"items\"]]\n",
    "    pubdate = [each[\"pubdate\"] for each in json_data[\"items\"]]\n",
    "    result_pd = pd.DataFrame({\n",
    "        \"제목\": title, \n",
    "        \"링크\": link, \n",
    "        \"저자\": author, \n",
    "        \"가격\": price,\n",
    "        \"할인 가격\": discount,\n",
    "        \"isbn\": isbn,\n",
    "        \"출판사\": publisher,\n",
    "        '출간일': pubdate\n",
    "        \n",
    "    }, columns=[\"제목\", \"저자\", \"출판사\", \"가격\", \"할인 가격\", \"출간일\", \"isbn\", \"링크\"])\n",
    "    return result_pd"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "7338505f",
   "metadata": {},
   "outputs": [],
   "source": [
    "langs = ['파이썬','python','Java','자바','자바스크립트','JavaScript','C언어','C++','C#','Visual Basic','비주얼 베이직','SQL','PHP','R']\n",
    "\n",
    "def search_func(name):\n",
    "    result_lang = []\n",
    "    for n in range(1, 1000, 100):\n",
    "        url = gen_search_url(name, n, 100)\n",
    "        json_result = get_result_onpage(url)\n",
    "        pd_result = get_fields(json_result)\n",
    "        pd_result['검색명'] = '{}'.format(name)\n",
    "        result_lang.append(pd_result)\n",
    "    result_lang = pd.concat(result_lang)\n",
    "    return result_lang"
   ]
  },
